										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"sqlReaderQuery": "SELECT DISTINCT cust.*\nFROM customers cust\nJOIN cards c ON cust.customer_id = c.customer_id\nWHERE c.billing_day = DAY(GETDATE())",
